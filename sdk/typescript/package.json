{
  "name": "@multidb/client",
  "version": "1.0.0",
  "description": "Publish-ready TypeScript client for the MultiDB Control Plane API v1.",
  "type": "module",
  "license": "MIT OR Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE-MIT",
    "LICENSE-APACHE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test test/*.mjs",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "typescript": "6.0.3"
  }
}
